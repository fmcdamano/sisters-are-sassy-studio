# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
# LOCAL DEV (SQLite — no setup required, file lives in prisma/dev.db):
DATABASE_URL="file:./dev.db"

# PRODUCTION (Neon PostgreSQL — uncomment and fill in before deploying):
# Also change prisma/schema.prisma datasource provider from "sqlite" to "postgresql"
# DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/sisters-are-sassy-studio?sslmode=require"

# ─────────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"

# The "from" address for booking confirmation emails.
# Requires Resend DNS verification of the domain (sistersaresassystudio.com).
# Use "onboarding@resend.dev" for local testing before the domain is verified.
FROM_EMAIL="bookings@sistersaresassystudio.com"

# The studio owner's inbox — receives scope change and reschedule notifications.
# Replace with the studio owner's actual Gmail address before deployment.
STUDIO_NOTIFICATION_EMAIL="sistersaresassystudio@gmail.com"

# ─────────────────────────────────────────────────
# SITE URL
# ─────────────────────────────────────────────────
# Used for QR code URLs, canonical links, and Open Graph images.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_SITE_URL="https://sistersaresassystudio.com"

# ─────────────────────────────────────────────────
# PHASE 3 — Archive Integration (DORMANT — do not fill in Phase 2)
# ─────────────────────────────────────────────────
# ARCHIVE_API_URL="https://omen-studio-archive.vercel.app"
# ARCHIVE_API_KEY="your-archive-api-key"
